# Copy to config.env and adjust before building or publishing.
#
#   cp config.env.example config.env

# GitHub org for py3.* clone URLs.
DOCKERSHELF_GITHUB_ORG=Dockershelf

# Docker image namespace for Debian builder containers (codename appended).
DOCKERSHELF_BUILDER_IMAGE=dockershelf-builder

# Tools image for meta-gbp / build (gbp, dch, dpkg-parsechangelog).
DOCKERSHELF_TOOLS_IMAGE=dockershelf-builder/tools

# Debian suites to generate builder images for (space-separated codenames).
DOCKERSHELF_SUITES=trixie unstable

# Default Python minor for Dockerfile generation (debiandirs/control source).
DOCKERSHELF_REFERENCE_PY=3.13

# Debian maintainer identity for debuild / changelog (optional).
# Leave unset to use `git config user.name` and `git config user.email`.
# DEBFULLNAME="Your Name"
# DEBEMAIL=you@example.com

# DigitalOcean droplet — APT repository publish target
DOCKERSHELF_DEPLOY_HOST=apt.dockershelf.example
DOCKERSHELF_DEPLOY_USER=deploy
DOCKERSHELF_DEPLOY_DIR=/var/www/debian
DOCKERSHELF_DEPLOY_INCOMING=/var/www/debian/incoming

# Public APT base URL (used in docs and future build-image.sh integration).
DOCKERSHELF_APT_URL=https://apt.dockershelf.example/debian
